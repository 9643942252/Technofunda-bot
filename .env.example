# Copy these into Railway's Variables tab for this service.
# Never commit this file with real values, and never paste real values into chat.

# --- Order mode: keep PAPER until you've reviewed live signals ---
ORDER_MODE=PAPER

# --- Zerodha (Kite Connect) --- leave blank to disable this broker
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# --- Groww --- leave blank to disable this broker
GROWW_API_KEY=
GROWW_TOTP_SECRET=

# --- Fyers --- leave blank to disable this broker
FYERS_APP_ID=
FYERS_ACCESS_TOKEN=

# PORT is auto-injected by Railway — do not set manually
